{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ProjectUpdateRequest",
  "title": "ProjectUpdateRequest",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "suspended"
      ]
    },
    "endDate": {
      "type": "string",
      "format": "date"
    },
    "currentPhase": {
      "type": "string"
    }
  }
}