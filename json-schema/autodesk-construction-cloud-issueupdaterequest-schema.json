{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/IssueUpdateRequest",
  "title": "IssueUpdateRequest",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "open",
        "pending",
        "in_review",
        "closed"
      ]
    },
    "dueDate": {
      "type": "string",
      "format": "date"
    },
    "assignedToId": {
      "type": "string"
    },
    "rootCauseId": {
      "type": "string"
    }
  }
}