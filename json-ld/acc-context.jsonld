{
  "@context": {
    "@version": 1.1,
    "acc": "https://aps.autodesk.com/en/docs/acc/v1/reference/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "Project": {
      "@id": "schema:Project",
      "@context": {
        "id": {"@id": "schema:identifier"},
        "accountId": {"@id": "acc:accountId"},
        "name": {"@id": "schema:name"},
        "startDate": {"@id": "schema:startDate", "@type": "xsd:date"},
        "endDate": {"@id": "schema:endDate", "@type": "xsd:date"},
        "projectValue": {"@id": "schema:priceRange"},
        "status": {"@id": "acc:projectStatus"},
        "jobNumber": {"@id": "schema:productID"},
        "city": {"@id": "schema:addressLocality"},
        "stateOrProvince": {"@id": "schema:addressRegion"},
        "country": {"@id": "schema:addressCountry"},
        "constructionType": {"@id": "acc:constructionType"},
        "deliveryMethod": {"@id": "acc:deliveryMethod"},
        "currentPhase": {"@id": "acc:currentPhase"}
      }
    },

    "Issue": {
      "@id": "schema:Action",
      "@context": {
        "id": {"@id": "schema:identifier"},
        "displayId": {"@id": "acc:issueDisplayId", "@type": "xsd:integer"},
        "title": {"@id": "schema:name"},
        "description": {"@id": "schema:description"},
        "status": {"@id": "acc:issueStatus"},
        "issueTypeId": {"@id": "acc:issueType"},
        "dueDate": {"@id": "schema:scheduledTime", "@type": "xsd:date"},
        "assignedToId": {"@id": "schema:agent"},
        "locationDescription": {"@id": "schema:locationCreated"},
        "createdBy": {"@id": "schema:creator"},
        "createdAt": {"@id": "schema:dateCreated", "@type": "xsd:dateTime"},
        "closedAt": {"@id": "schema:endTime", "@type": "xsd:dateTime"}
      }
    },

    "ProjectUser": {
      "@id": "schema:OrganizationRole",
      "@context": {
        "id": {"@id": "schema:identifier"},
        "email": {"@id": "schema:email"},
        "name": {"@id": "schema:name"},
        "status": {"@id": "acc:userStatus"},
        "roleIds": {"@id": "schema:roleName", "@container": "@set"}
      }
    }
  }
}
